# ═══════════════════════════════════════════════════════════════════
# SportsCenterSystem — Primjer .env datoteke
# ═══════════════════════════════════════════════════════════════════
# KOPIRATI U .env FAJL I POPUNITI VRIJEDNOSTI

# ── MySQL Konfiguracija ──────────────────────────────────────────────
DB_ROOT_PASSWORD=root
DB_USER=sportcenter
DB_PASSWORD=sportcenter123

# ── User Service ─────────────────────────────────────────────────────
USER_SERVICE_PORT=8081
USER_DB_PORT=3307
USER_DB_NAME=sportcenter_user_db
USER_DB_HOST=mysql-user
USER_DB_URL=jdbc:mysql://mysql-user:3306/sportcenter_user_db?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC

# ── Resource Service ─────────────────────────────────────────────────
RESOURCE_SERVICE_PORT=8082
RESOURCE_DB_PORT=3308
RESOURCE_DB_NAME=sportcenter_resource_db
RESOURCE_DB_HOST=mysql-resource
RESOURCE_DB_URL=jdbc:mysql://mysql-resource:3306/sportcenter_resource_db?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC

# ── Booking Service ──────────────────────────────────────────────────
BOOKING_SERVICE_PORT=8083
BOOKING_DB_PORT=3309
BOOKING_DB_NAME=sportcenter_booking_db
BOOKING_DB_HOST=mysql-booking
BOOKING_DB_URL=jdbc:mysql://mysql-booking:3306/sportcenter_booking_db?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC

# ── Payment Service ──────────────────────────────────────────────────
PAYMENT_SERVICE_PORT=8084
PAYMENT_DB_PORT=3310
PAYMENT_DB_NAME=sportcenter_payment_db
PAYMENT_DB_HOST=mysql-payment
PAYMENT_DB_URL=jdbc:mysql://mysql-payment:3306/sportcenter_payment_db?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC

# ── Hibernate/JPA ────────────────────────────────────────────────────
JPA_HIBERNATE_DDL_AUTO=update
JPA_SHOW_SQL=true
JPA_FORMAT_SQL=true

